# ===== 입낚 환경변수 예시 =====
# 데이터베이스 (SQLite, 로컬 개발)
DATABASE_URL="file:./dev.db"

# 세션 시크릿 (운영 시 변경)
SESSION_SECRET="ipnak-dev-secret-change-me"

# ===== 추후 소셜 로그인 연동 (현재는 mock) =====
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ===== AI 포인트 추천 (관리자 사이트 관리 > AI API 연결에서도 등록 가능) =====
# 배포 환경에서는 아래 환경 변수를 우선 사용합니다.
OPENAI_API_KEY=""
OPENAI_RECOMMEND_MODEL="gpt-4.1-mini"
NAVER_SEARCH_CLIENT_ID=""
NAVER_SEARCH_CLIENT_SECRET=""

# ===== 추후 지도 API 연동 (현재는 Leaflet/OSM) =====
NEXT_PUBLIC_KAKAO_MAP_KEY=""
NEXT_PUBLIC_NAVER_MAP_KEY=""

# ===== 추후 결제/커머스 연동 (현재는 mock booking) =====
PAYMENT_API_KEY=""
COMMERCE_AFFILIATE_KEY=""

# ===== AI 카메라 측정 모듈 (/measure, /diary) =====
# 측정 서버 API (미설정 시 로컬 저장만 사용, 동기화 대기)
NEXT_PUBLIC_API_BASE_URL=""
# "false" 로 바꾸면 실제 서버 API 호출 (기본: 목 모드)
NEXT_PUBLIC_USE_MOCK_API="true"
# 기상청 단기예보(초단기실황) API 키 — 날씨 자동 태그 (없어도 측정 동작)
NEXT_PUBLIC_WEATHER_API_KEY=""
# 바다누리(국립해양조사원) API 키 — 물때 자동 태그 (없어도 측정 동작)
NEXT_PUBLIC_TIDE_API_KEY=""
# 위치명 역지오코딩은 위의 NEXT_PUBLIC_KAKAO_MAP_KEY 를 재사용
