// 입낚 (ipnak) — Prisma schema (SQLite)
// 필드명은 영어, UI 라벨은 한국어로 표기한다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== 사용자 / 인증 =====
// 참고: SQLite는 Prisma enum을 지원하지 않으므로 role/status 등은 String + 주석으로 관리한다.
// Role: SUPER_ADMIN | ANGLER | PARTNER

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  nickname      String
  role          String   @default("ANGLER") // Role
  avatarUrl     String?
  bio           String?
  interests     String?  // JSON array of category slugs
  region        String?
  createdAt     DateTime @default(now())

  posts          Post[]
  comments       Comment[]
  likes          Like[]
  bookmarks      Bookmark[]
  shareEvents    ShareEvent[]
  reportsMade    Report[]          @relation("Reporter")
  trips          FishingTrip[]
  fishingPoints  FishingPoint[]
  catchRecords   CatchRecord[]
  products       Product[]
  tournamentEntries TournamentEntry[]
  bookings       Booking[]
  notifications  Notification[]
  sessions       Session[]
  followedBy     Follow[]          @relation("Following")
  following      Follow[]          @relation("Follower")
  listings       ReservationListing[]
  marketListings MarketListing[]
  marketFavorites MarketFavorite[]
  marketChats    MarketChat[]      @relation("MarketBuyer")
  marketMessages MarketMessage[]
  referralEarnings ReferralEvent[] @relation("ReferralEarner")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ===== 게시글 / 피드 =====
// postType: GENERAL | FISHING_POINT | TOURNAMENT
// visibility: PUBLIC | FOLLOWERS | PRIVATE | BLURRED
// kind: FEED(피싱 피드 — 사진 위주 인스타형) | LOG(조행기 — 카페형 게시판 글)
model Post {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postType     String   @default("GENERAL")
  kind         String   @default("FEED")   // FEED | LOG
  title        String?                      // 조행기 제목
  body         String?                      // 조행기 본문(긴 글)
  boardCategory String?                     // 조행기 게시판 카테고리 slug
  viewCount    Int      @default(0)         // 조행기 조회수
  caption      String?
  speciesName  String?
  categoryPath String?  // 예: 바다낚시 > 갯바위 > 찌낚시
  fishingType  String?
  sizeCm       Float?
  region       String?
  lat          Float?
  lng          Float?
  visibility   String   @default("PUBLIC")
  hidden       Boolean  @default(false)
  hashtags     String?  // JSON array
  createdAt    DateTime @default(now())

  fishingPointId String?
  fishingPoint   FishingPoint? @relation(fields: [fishingPointId], references: [id])
  tournamentEntryId String?

  images       PostImage[]
  comments     Comment[]
  likes        Like[]
  bookmarks    Bookmark[]
  shareEvents  ShareEvent[]
  reports      Report[]
  productTags  PostProductTag[]
  referralEvents ReferralEvent[]
  curationFeatures CurationFeature[]
}

// ===== 메인 동적 섹션 (최고관리자가 정의·정렬·노출 관리) =====
// type: SPECIES(어종) | REGION(지역) | THEME(동행/테마) | BEST(금주·월간) | FEED
// mode: AUTO(인기 점수순 자동) | MANUAL(관리자 고정글)
model CurationSection {
  id        String   @id @default(cuid())
  key       String   @unique          // 렌더링/CurationFeature.section 에 사용하는 안정 키
  title     String
  type      String   @default("SPECIES")
  params    String?                    // JSON: { species?, region?, theme?, keywords?, period?, style? }
  mode      String   @default("AUTO")
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ===== 프로/유튜버 (최고관리자가 등록, PRO 섹션에서 추천 글 노출) =====
model ProAngler {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String?
  bio          String?
  linkedUserId String?                  // 연결할 회원 계정(있으면 그 계정 글을 자동 노출)
  visible      Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

// ===== 메인 큐레이션 (최고관리자가 섹션별로 노출할 글을 선택) =====
// section: member_pick | best_weekly | best_monthly | point_<species-slug> | region_* | pro_<proId> ...
model CurationFeature {
  id        String   @id @default(cuid())
  section   String                          // 노출 섹션 키
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  order     Int      @default(0)            // 섹션 내 정렬(작을수록 먼저)
  visible   Boolean  @default(true)
  pinnedById String?                        // 고른 관리자
  createdAt DateTime @default(now())
  @@unique([section, postId])
  @@index([section])
}

model PostImage {
  id       String  @id @default(cuid())
  postId   String
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  url      String
  alt      String?
  order    Int     @default(0)
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  parentId  String?  // 대댓글
  parent    Comment? @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  @@unique([followerId, followingId])
}

model ShareEvent {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  channel   String   @default("link")
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id])
  targetType  String   @default("POST") // POST | COMMENT | USER
  reason      String
  status      String   @default("PENDING") // PENDING | RESOLVED | REJECTED
  createdAt   DateTime @default(now())
}

// ===== GPS / 동선 / 피싱 포인트 =====
model FishingTrip {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  distanceM   Float    @default(0)
  durationSec Int      @default(0)
  catchCount  Int      @default(0)
  topSpecies  String?
  region      String?
  routePoints RoutePoint[]
  fishingPoints FishingPoint[]
}

model RoutePoint {
  id        String   @id @default(cuid())
  tripId    String
  trip      FishingTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  recordedAt DateTime @default(now())
  order     Int      @default(0)
}

// PC Point / Catch Point / 피싱 포인트
model FishingPoint {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId      String?
  trip        FishingTrip? @relation(fields: [tripId], references: [id])
  lat         Float
  lng         Float
  accuracy    Float?
  speciesName String?
  sizeCm      Float?
  photoUrl    String?
  gearSetup   String?  // 채비 요약 텍스트
  region      String?
  visibility  String   @default("EXACT") // EXACT | BLUR_100 | BLUR_500 | PRIVATE
  createdAt   DateTime @default(now())

  catchRecord CatchRecord?
  posts       Post[]
}

model CatchRecord {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fishingPointId String?  @unique
  fishingPoint   FishingPoint? @relation(fields: [fishingPointId], references: [id])
  speciesName    String
  categoryPath   String?
  sizeCm         Float?
  photoUrl       String?
  shareToFeed    Boolean  @default(true)
  // 스마트 룰러 측정 데이터
  originalImageUrl String?
  measuredImageUrl String?
  calibrationStart String? // JSON {x,y}
  calibrationEnd   String? // JSON {x,y}
  calibrationLengthCm Float?
  fishHeadPoint    String? // JSON {x,y}
  fishTailPoint    String? // JSON {x,y}
  measuredLengthCm Float?
  confidence       Float?
  tamperFlag       Boolean @default(false)
  gear           GearSetup?
  createdAt      DateTime @default(now())
}

model GearSetup {
  id            String   @id @default(cuid())
  catchRecordId String   @unique
  catchRecord   CatchRecord @relation(fields: [catchRecordId], references: [id], onDelete: Cascade)
  rod           String?
  reel          String?
  line          String?
  leader        String?
  lure          String?
  bait          String?
  rig           String?
  note          String?
}

// ===== 분류 체계 / 어종 =====
model FishingCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  kind      String   // MAIN | ENV | METHOD | ACCESS
  parent    String?
  water     String?  // FRESH | SEA | BOTH
  order     Int      @default(0)
}

model FishSpecies {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  water     String   // FRESH | SEA
  order     Int      @default(0)
}

// ===== 피싱 태그 / 상품 (네이버 쇼핑 커넥트형 제휴) =====
model Product {
  id          String   @id @default(cuid())
  sellerId    String?
  seller      User?    @relation(fields: [sellerId], references: [id])
  name        String
  brand       String?
  category    String   // ROD | REEL | LINE | LEADER | LURE | WORM | HOOK ...
  price       Int      @default(0)
  imageUrl    String?
  buyUrl      String?
  description String?
  feeRate     Int      @default(10)         // 리퍼럴 수수료율(%)
  affiliateCode String?                     // 제휴/리퍼럴 코드 (실연동 시 사용)
  createdAt   DateTime @default(now())
  postTags    PostProductTag[]
  referralEvents ReferralEvent[]
}

// 피싱 태그 리퍼럴 추적 — 클릭/전환(구매) 이벤트와 작성자 적립 수익
// type: CLICK(클릭) | CONVERSION(구매 전환)
// source: MOCK(목 시뮬레이션) | LIVE(실 제휴 API)
model ReferralEvent {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  earnerId   String                          // 적립 대상(글 작성자)
  earner     User     @relation("ReferralEarner", fields: [earnerId], references: [id], onDelete: Cascade)
  visitorId  String?                          // 클릭/구매한 사용자(있으면)
  type       String   @default("CLICK")       // CLICK | CONVERSION
  source     String   @default("MOCK")        // MOCK | LIVE
  amount     Int      @default(0)             // 구매 금액
  reward     Int      @default(0)             // 작성자 적립 리워드
  externalId String?                          // 제휴사 주문/클릭 ID
  createdAt  DateTime @default(now())
  @@index([earnerId])
  @@index([postId])
}

model PostProductTag {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  posX      Float    @default(0.5) // 사진 위 핀 위치 (0~1)
  posY      Float    @default(0.5)
}

// ===== 대회 =====
model Tournament {
  id          String   @id @default(cuid())
  title       String
  type        String   // WEEKLY | MONTHLY | GRAND
  speciesName String?
  description String?
  rules       String?
  startAt     DateTime
  endAt       DateTime
  status      String   @default("UPCOMING") // UPCOMING | ONGOING | ENDED
  bannerUrl   String?
  createdAt   DateTime @default(now())
  entries     TournamentEntry[]
}

model TournamentEntry {
  id           String   @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speciesName  String
  sizeCm       Float
  photoUrl     String?
  measuredImageUrl String?
  region       String?
  lat          Float?
  lng          Float?
  status       String   @default("REVIEW") // REVIEW | APPROVED | REJECTED
  // 스마트 룰러 측정 데이터
  originalImageUrl     String?
  calibrationStart     String?  // JSON {x,y}
  calibrationEnd       String?  // JSON {x,y}
  calibrationLengthCm  Float?
  fishHeadPoint        String?  // JSON {x,y}
  fishTailPoint        String?  // JSON {x,y}
  measuredLengthCm     Float?
  confidence           Float?
  tamperFlag           Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ===== 예약 =====
model ReservationListing {
  id          String   @id @default(cuid())
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  name        String
  category    String   // BOAT | PENSION | PAID_POND | SEAT | SEA_PENSION | GUIDE
  region      String
  address     String?
  lat         Float?
  lng         Float?
  imageUrl    String?
  images      String?  // JSON array
  description String?
  targetSpecies String? // JSON array
  amenities   String?  // JSON array
  services    String?  // JSON array
  price       Int      @default(0)
  maxPeople   Int      @default(4)
  cancelPolicy String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  slots       ReservationSlot[]
  bookings    Booking[]
}

model ReservationSlot {
  id          String   @id @default(cuid())
  listingId   String
  listing     ReservationListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date        DateTime
  timeLabel   String?
  capacity    Int      @default(4)
  booked      Int      @default(0)
}

model Booking {
  id          String   @id @default(cuid())
  listingId   String
  listing     ReservationListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  people      Int      @default(1)
  totalPrice  Int      @default(0)
  status      String   @default("REQUESTED") // REQUESTED | CONFIRMED | CANCELLED | DONE
  createdAt   DateTime @default(now())
}

// ===== 알림 / 관리자 로그 / 배너 =====
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  detail    String?
  createdAt DateTime @default(now())
}

// 사이트 운영 설정 (key-value). 예: shop_menu_enabled = "true" | "false"
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  body      String?
  imageUrl  String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ===== 중고나라 (중고 거래 마켓플레이스) =====
// category: REEL | ROD | LURE | WORM | LINE | WADER | TACKLEBOX | COOLER | LIFEVEST | APPAREL | ELECTRONICS | ETC
// condition: NEW(새상품) | USED(중고)
// status: SELLING(판매중) | RESERVED(예약중) | SOLD(판매완료)
model MarketListing {
  id          String   @id @default(cuid())
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  category    String
  condition   String   @default("USED")
  price       Int      @default(0)
  region      String?
  description String?
  status      String   @default("SELLING")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  images      MarketImage[]
  favorites   MarketFavorite[]
  chats       MarketChat[]
}

model MarketImage {
  id        String   @id @default(cuid())
  listingId String
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
}

model MarketFavorite {
  id        String   @id @default(cuid())
  listingId String
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([listingId, userId])
}

model MarketChat {
  id        String   @id @default(cuid())
  listingId String
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation("MarketBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  messages  MarketMessage[]
  @@unique([listingId, buyerId])
}

model MarketMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      MarketChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

